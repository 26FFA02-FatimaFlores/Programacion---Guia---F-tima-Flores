Algoritmo act1_incs1_lecc10
	Definir corte Como Entero
    Definir confirma Como Caracter
    Para corte <- 1 Hasta 8 Hacer
        Escribir "¿Fuiste a la peluquería?:"
        Leer confirma
        Escribir "Sello ", corte, " de 8 acumulado"
    FinPara
    Escribir "Obtuviste tu corte gratis,felicidades "
FinAlgoritmo